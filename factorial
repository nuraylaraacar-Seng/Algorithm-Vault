#include <stdio.h>

int main()
{
    int num,original,kalan,sum,i,factorial;
    
    printf("1-500 arasi Strong Number sayilari:\n");
    
    for(num=1;num<=500;num++){
        original=num;
        sum=0;
        
        while(original>0){
         kalan=original%10;
         
         factorial=1;
         for(i=1;i<=kalan;i++){
         factorial=factorial*i;
         }
         
         sum+=factorial;
         original/=10;
        }
      
        }
        
        
          if(sum==num){
        printf("%d",num);
        
        
    }
    return 0;
}
